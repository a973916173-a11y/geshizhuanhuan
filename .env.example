# Copy to `.env.local` (never commit `.env.local`). Set the same values in Vercel → Settings → Environment Variables.

# --- Database (Prisma) — PostgreSQL required ---
# Example local Docker: docker run -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:16
# DATABASE_URL="postgresql://postgres:dev@localhost:5432/postgres?schema=public"
# Hosted free tier: https://neon.tech — paste connection string with ?sslmode=require
DATABASE_URL=

# --- NextAuth (required) ---
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- OAuth (optional — any combo; login page lists whatever is configured) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application).
# Authorized redirect URIs must include (replace domain):
#   https://YOUR_DOMAIN/api/auth/callback/google
# Same GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET on Vercel Production + local .env.local for dev.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — JWT secret is generated at runtime from the key (keep key multi-line or use \n in env)
# Apple Developer: Services ID → APPLE_ID, Team ID, Key ID, .p8 private key contents
APPLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# GitHub — https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL (must match deployment):
#   https://YOUR_DOMAIN/api/auth/callback/github
# Production example: https://geshizhuanhuan-three.vercel.app/api/auth/callback/github
# Set these on Vercel project **geshizhuanhuan** (same names). Aliases also work:
# AUTH_GITHUB_ID / AUTH_GITHUB_SECRET
GITHUB_ID=
GITHUB_SECRET=

# Meta / Facebook Login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- PayPal ---
# For localhost testing use a Sandbox app + PAYPAL_MODE=sandbox + Sandbox Client ID/Secret.
PAYPAL_MODE=sandbox

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

NEXT_PUBLIC_PAYPAL_CLIENT_ID=

PRICE_PRO=2.00
PRICE_MAX=5.00

# Optional: demo unlock buttons in payment modal (non-production only)
# NEXT_PUBLIC_PAYPAL_SHOW_DEMO=false

# --- Google AdSense (optional overrides — defaults are set in src/lib/ads-config.ts) ---
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# NEXT_PUBLIC_ADSENSE_SLOT_LEFT=
# NEXT_PUBLIC_ADSENSE_SLOT_RIGHT=
# NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
